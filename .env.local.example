# Supabase — https://supabase.com থেকে পাবেন
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin Panel Password — যেকোনো পাসওয়ার্ড দিন
ADMIN_PASSWORD=admin123

# আপনার WhatsApp নম্বর (দেশকোড সহ, + ছাড়া)
NEXT_PUBLIC_WHATSAPP_NUMBER=8801XXXXXXXXX

# আপনার Facebook Page নাম বা লিংক
NEXT_PUBLIC_FB_PAGE=https://m.me/your-page-name

# সাইট লোগো (public/logo.png বা Supabase URL)
NEXT_PUBLIC_SITE_LOGO=/corelab.jpg
